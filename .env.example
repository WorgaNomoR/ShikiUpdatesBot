# Скопируй этот файл в .env и заполни значениями
# cp .env.example .env

# ── Обязательные ──────────────────────────────

# Токен бота от @BotFather
BOT_TOKEN=токен_от_BotFather

# Твой Telegram ID (узнать у @userinfobot)
OWNER_ID=123456789

# Ник отслеживаемого пользователя на Shikimori (например, WNR)
SHIKI_USER=ник_на_shikimori

# ── Необязательные ────────────────────────────

# Отображаемое имя пользователя в сообщениях.
# По умолчанию берётся ник из SHIKI_USER. Раскомментируй, чтобы переопределить.
# DISPLAY_NAME=Имя

# Домен Shikimori — менять при смене зеркала. По умолчанию https://shikimori.io
# SHIKI_BASE_URL=https://shikimori.io

# Интервалы в секундах (в скобках — значения по умолчанию).
# CHECK_INTERVAL=900          # проверка истории/избранного (15 мин)
# ERROR_NOTIFY_INTERVAL=1800  # антиспам уведомлений об ошибке (30 мин)
# FULL_SYNC_INTERVAL=21600    # ресинк статистики за всё время (6 ч)

# Папка для файлов состояния и статистики.
# По умолчанию /data. Раскомментируй, чтобы переопределить.
# DATA_DIR=/data

# Порт healthcheck-сервера (эндпоинт /health).
# По умолчанию 8080. Большинство хостингов прокидывают PORT сами.
# PORT=8080
